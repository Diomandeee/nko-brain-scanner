  "proverbs": {
    "nko_script": {
      "description": "Proverbs in N'Ko script (from vocabulary.json)",
      "entries": [
        {
          "id": "prov-nko-001",
          "nko": "ߛߏ߬ ߕߍ߫ ߦߋ߲߬",
          "transliteration": "sɔ te yan",
          "literal": "there is no horse here",
          "meaning": "Don't expect the impossible"
        },
        {
          "id": "prov-nko-002",
          "nko": "ߡߐ߱ ߞߊ߬ ߝߊ߲߬ߞߊ ߛߐ߬ߘߐ߲",
          "transliteration": "mɔgɔ ka fanga sɔrɔ",
          "literal": "a person finds strength",
          "meaning": "Strength comes through community"
        },
        {
          "id": "prov-nko-003",
          "nko": "ߓߏ߬ߟߏ ߘߏ߫ ߕߍ߫ ߞߊ߬ ߡߏ߬ߙߌ ߕߏ߫",
          "transliteration": "bolo dɔ te ka mori to",
          "literal": "one hand cannot tie a bundle",
          "meaning": "Cooperation is necessary"
        },
        {
          "id": "prov-nko-004",
          "nko": "ߞߎ߲߬ߠߊ ߡߊ߲ ߞߊ߫ ߖߎ߯",
          "transliteration": "kunna man ka ju",
          "literal": "knowledge is not expensive",
          "meaning": "Education is invaluable"
        },
        {
          "id": "prov-nko-005",
          "nko": "ߛߏ߬ ߡߊ߫ ߓߏ߲ ߖߏ߬",
          "transliteration": "sɔ ma bɔn jɔ",
          "literal": "the horse did not build the stable",
          "meaning": "Be grateful, don't take things for granted"
        },
        {
          "id": "prov-nko-006",
          "nko": "ߞߐ ߡߊ߫ ߥߴߊ߬ ߖߌ ߡߊ߬",
          "transliteration": "kɔ ma wa a ji ma",
          "literal": "the back did not see its own water",
          "meaning": "We cannot see our own faults"
        }
      ]
    },
    "bambara": {
      "description": "Bambara proverbs in Latin script (from proverbs.json)",
      "entries": [
        {"id": "prov-bam-001", "original": "Mɔgɔ tɛ se ka jiri bɛɛ farakolo kɔnɔ.", "transliteration": "Mogo te se ka jiri be farakolo kono.", "english": "One cannot hold all trees in one armpit.", "meaning": "No one can do everything alone. We all need help from others.", "language": "Bambara"},
        {"id": "prov-bam-002", "original": "Hakili ka fisa ni wari ye.", "transliteration": "Hakili ka fisa ni wari ye.", "english": "Wisdom is better than money.", "meaning": "Knowledge and good judgment are more valuable than wealth.", "language": "Bambara"},
        {"id": "prov-bam-003", "original": "Sira tɛ kelen ye.", "transliteration": "Sira te kelen ye.", "english": "The road is not one.", "meaning": "There are many paths to reach your goal.", "language": "Bambara"},
        {"id": "prov-bam-004", "original": "Jɛ ka fisa ni baarakɛ ye.", "transliteration": "Je ka fisa ni baarake ye.", "english": "Unity is better than work.", "meaning": "Working together achieves more than working alone.", "language": "Bambara"},
        {"id": "prov-bam-005", "original": "Kuma man di, nka a bɛ fɔ.", "transliteration": "Kuma man di, nka a be fo.", "english": "The word is not sweet, but it must be said.", "meaning": "Sometimes difficult truths need to be spoken.", "language": "Bambara"},
        {"id": "prov-bam-006", "original": "Dusu ka bon ni waritigi ye.", "transliteration": "Dusu ka bon ni waritigi ye.", "english": "A big heart is greater than a rich person.", "meaning": "Generosity of spirit matters more than material wealth.", "language": "Bambara"},
        {"id": "prov-bam-007", "original": "Balo bɛ sɔn bɔ.", "transliteration": "Balo be son bo.", "english": "Life comes from patience.", "meaning": "Patience is essential for survival and success.", "language": "Bambara"},
        {"id": "prov-bam-008", "original": "Mɔgɔ kɔnɔ ye mɔgɔ ye.", "transliteration": "Mogo kono ye mogo ye.", "english": "The inside of a person is the person.", "meaning": "Character defines who you truly are, not appearances.", "language": "Bambara"},
        {"id": "prov-bam-009", "original": "Tuma tɛ mɔgɔ ma, mɔgɔ bɛ tuma ma.", "transliteration": "Tuma te mogo ma, mogo be tuma ma.", "english": "Time is not for man, man is for time.", "meaning": "We must adapt to circumstances, not expect them to adapt to us.", "language": "Bambara"},
        {"id": "prov-bam-010", "original": "Muso ɲuman ye so ɲuman ye.", "transliteration": "Muso nyuman ye so nyuman ye.", "english": "A good woman makes a good home.", "meaning": "The strength of a family often comes from its women.", "language": "Bambara"},
        {"id": "prov-bam-011", "original": "Yɛlɛma bɛ ɲɛ na.", "transliteration": "Yelema be nye na.", "english": "Change is before us.", "meaning": "Change is inevitable and always approaching.", "language": "Bambara"},
        {"id": "prov-bam-012", "original": "Baa tɛ a faga, baa tɛ a balo.", "transliteration": "Baa te a faga, baa te a balo.", "english": "The river doesn't kill it, the river doesn't feed it.", "meaning": "Some forces neither help nor harm—they simply exist.", "language": "Bambara"},
        {"id": "prov-bam-013", "original": "Sababu tɛ baara la.", "transliteration": "Sababu te baara la.", "english": "There is no excuse in work.", "meaning": "Hard work speaks for itself; excuses don't matter.", "language": "Bambara"},
        {"id": "prov-bam-014", "original": "Nkalontan ye tila ye.", "transliteration": "Nkalontan ye tila ye.", "english": "Truth is the sun.", "meaning": "Truth always shines through eventually.", "language": "Bambara"},
        {"id": "prov-bam-015", "original": "Den ye wari ye.", "transliteration": "Den ye wari ye.", "english": "A child is wealth.", "meaning": "Children are the greatest treasure.", "language": "Bambara"},
        {"id": "prov-bam-021", "original": "Dɔɔnin dɔɔnin bɛ wara so.", "transliteration": "Doonin doonin be wara so.", "english": "Little by little, the lion's den is reached.", "meaning": "Patience and persistence lead to great achievements.", "language": "Bambara"},
        {"id": "prov-bam-022", "original": "Ko kɔrɔ ye ko kura ba ye.", "transliteration": "Ko koro ye ko kura ba ye.", "english": "An old thing is the mother of a new thing.", "meaning": "The past informs and creates the future.", "language": "Bambara"},
        {"id": "prov-bam-023", "original": "Mɔgɔ si tɛ bɔ jiri kelen na.", "transliteration": "Mogo si te bo jiri kelen na.", "english": "No one comes from a single tree.", "meaning": "Everyone has a community and roots.", "language": "Bambara"},
        {"id": "prov-bam-024", "original": "Jatigi ɲuman ka fisa ni wari ye.", "transliteration": "Jatigi nyuman ka fisa ni wari ye.", "english": "A good host is better than money.", "meaning": "Hospitality and kindness outweigh material possessions.", "language": "Bambara"}
      ]
    },
    "mandinka": {
      "description": "Mandinka proverbs in Latin script (from proverbs.json)",
      "entries": [
        {"id": "prov-man-016", "original": "Kontondila fila man ɲi.", "transliteration": "Kontondila fila man nyi.", "english": "Two captains are not good.", "meaning": "Too many leaders spoil the mission.", "language": "Mandinka"},
        {"id": "prov-man-017", "original": "Ñing fanang buka taa kewo.", "transliteration": "Nying fanang buka taa kewo.", "english": "This too shall pass.", "meaning": "No hardship lasts forever.", "language": "Mandinka"},
        {"id": "prov-man-018", "original": "Moo bete mu dookuo le ti.", "transliteration": "Moo bete mu dookuo le ti.", "english": "A good person is known by their deeds.", "meaning": "Actions reveal true character.", "language": "Mandinka"},
        {"id": "prov-man-019", "original": "Kuu kiling be moo buuña.", "transliteration": "Kuu kiling be moo buunya.", "english": "One matter humbles a person.", "meaning": "Everyone has their weakness.", "language": "Mandinka"},
        {"id": "prov-man-020", "original": "Kambaning buka laa a faamaa kono.", "transliteration": "Kambaning buka laa a faamaa kono.", "english": "A baby doesn't sleep in its father's belly.", "meaning": "Each person must carry their own burden.", "language": "Mandinka"}
      ]
    }
  },

