  "proverbs": [
    {
      "nko": "ߛߏ߬ ߕߍ߫ ߦߋ߲߬",
      "trans": "sɔ te yan",
      "literal": "there is no horse here",
      "meaning": "Don't expect the impossible"
    },
    {
      "nko": "ߡߐ߱ ߞߊ߬ ߝߊ߲߬ߞߊ ߛߐ߬ߘߐ߲",
      "trans": "mɔgɔ ka fanga sɔrɔ",
      "literal": "a person finds strength",
      "meaning": "Strength comes through community"
    },
    {
      "nko": "ߓߏ߬ߟߏ ߘߏ߫ ߕߍ߫ ߞߊ߬ ߡߏ߬ߙߌ ߕߏ߫",
      "trans": "bolo dɔ te ka mori to",
      "literal": "one hand cannot tie a bundle",
      "meaning": "Cooperation is necessary"
    },
    {
      "nko": "ߞߎ߲߬ߠߊ ߡߊ߲ ߞߊ߫ ߖߎ߯",
      "trans": "kunna man ka ju",
      "literal": "knowledge is not expensive",
      "meaning": "Education is invaluable"
    },
    {
      "nko": "ߛߏ߬ ߡߊ߫ ߓߏ߲ ߖߏ߬",
      "trans": "sɔ ma bɔn jɔ",
      "literal": "the horse did not build the stable",
      "meaning": "Be grateful, don't take things for granted"
    },
    {
      "nko": "ߞߐ ߡߊ߫ ߥߴߊ߬ ߖߌ ߡߊ߬",
      "trans": "kɔ ma wa a ji ma",
      "literal": "the back did not see its own water",
      "meaning": "We cannot see our own faults"
    }
  ],
